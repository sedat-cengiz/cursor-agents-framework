## React 19 Core Patterns

### Actions API (Yeni)
```tsx
function CreateForm() {
  const [state, action, isPending] = useActionState(async (prev, formData) => {
    const result = await createItem(formData);
    if (!result.success) return { error: result.message };
    return { success: true };
  }, { error: null });

  return (
    <form action={action}>
      <input name="name" required />
      <button disabled={isPending}>{isPending ? 'Kaydediliyor...' : 'Kaydet'}</button>
      {state.error && <Alert type="error" message={state.error} />}
    </form>
  );
}
```

### use() Hook (Yeni)
```tsx
// Promise'i dogrudan component icinde resolve et
function UserProfile({ userPromise }: { userPromise: Promise<User> }) {
  const user = use(userPromise); // Suspense ile calısır
  return <div>{user.name}</div>;
}
```

## Component Patterns

### Compound Component
```tsx
const DataTable = ({ children }: PropsWithChildren) => { ... };
DataTable.Header = ({ columns }) => { ... };
DataTable.Body = ({ data, renderRow }) => { ... };
DataTable.Pagination = ({ total, pageSize }) => { ... };
DataTable.Filters = ({ filters, onChange }) => { ... };

// Kullanim
<DataTable>
  <DataTable.Filters filters={filters} onChange={setFilters} />
  <DataTable.Header columns={columns} />
  <DataTable.Body data={items} renderRow={(item) => <Row item={item} />} />
  <DataTable.Pagination total={total} pageSize={20} />
</DataTable>
```

### Page Component Template
```tsx
export default function ItemListPage() {
  const { t } = useTranslation();
  const [filters, setFilters] = useSearchParams();
  const { data, isLoading, error } = useItems(filters);

  if (error) return <ErrorResult error={error} />;

  return (
    <PageContainer title={t('items.title')}>
      <FilterBar filters={filters} onChange={setFilters} />
      <DataTable loading={isLoading} data={data?.items} columns={columns} />
      <Pagination total={data?.totalCount} />
    </PageContainer>
  );
}
```

