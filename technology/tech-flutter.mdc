@DriftDatabase(tables: [Items, SyncLogs])
class AppDatabase extends _$AppDatabase {
  AppDatabase(super.e);
  @override int get schemaVersion => 2;
  @override MigrationStrategy get migration => MigrationStrategy(
    onUpgrade: stepByStep(from1To2: (m, schema) async => m.addColumn(schema.items, schema.items.barcode)),
  );
}
