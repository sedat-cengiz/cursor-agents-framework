## Testing Stratejisi
```dart
// Widget test
testWidgets('ItemCard onTap fires callback', (tester) async {
  var tapped = false;
  await tester.pumpWidget(MaterialApp(home: ItemCard(item: mockItem, onTap: () => tapped = true)));
  await tester.tap(find.byType(ItemCard));
  expect(tapped, isTrue);
});
// Golden test (guncelleme: flutter test --update-goldens)
testWidgets('LoginPage golden', (tester) async {
  await tester.pumpWidget(const MaterialApp(home: LoginPage()));
  await expectLater(find.byType(LoginPage), matchesGoldenFile('goldens/login_page.png'));
});
// Riverpod test — ProviderContainer ile override
test('ItemList fetches on build', () async {
  final container = ProviderContainer(
    overrides: [itemRepositoryProvider.overrideWithValue(MockItemRepository())],
  );
  container.listen(itemListProvider, listener.call, fireImmediately: true);
  await container.read(itemListProvider.future);
  verify(() => listener(any(), any(that: isA<AsyncData<List<Item>>>()))).called(1);
});
```

